# Connection string do Neon (ou outro Postgres). Copia do dashboard do Neon.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Password mestre partilhada pela equipa para entrar no site.
MASTER_PASSWORD="troca-me-para-uma-password-forte"

# PIN de 4 dígitos para ações sensíveis (apagar moldes/peças).
PIN_CODE="1234"
